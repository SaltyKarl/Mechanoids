<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<!-- ===== Beam Motes ===== -->
	<ThingDef ParentName="MoteBase">
		<defName>APM_Mote_HazeBeamRepeaterLaser</defName>
		<thingClass>MoteDualAttached</thingClass>
		<altitudeLayer>MoteOverhead</altitudeLayer>
		<mote>
			<fadeInTime>0.1</fadeInTime>
			<fadeOutTime>0.1</fadeOutTime>
			<solidTime>0.1</solidTime>
			<rotateTowardsTarget>True</rotateTowardsTarget>
			<scaleToConnectTargets>True</scaleToConnectTargets>
		</mote>
		<drawOffscreen>true</drawOffscreen>
		<graphicData>
			<texPath>Things/Mote/GraserBeam</texPath>
			<graphicClass>Graphic_MoteWithAgeSecs</graphicClass>
			<shaderType>MoteBeam</shaderType>
			<shaderParameters>
				<_ExtraTexA>/Things/Mote/BeamSecondaryNoise_A</_ExtraTexA>
				<_ExtraTexB>/Things/Mote/BeamSecondaryNoise_B</_ExtraTexB>
				<_ScrollSpeedA>0</_ScrollSpeedA>
				<_ScrollSpeedB>0</_ScrollSpeedB>
				<_Intensity>2</_Intensity>
			</shaderParameters>
			<color>(85, 175, 95)</color>
		</graphicData>
	</ThingDef>

	<ThingDef ParentName="MoteBase">
		<defName>APM_Mote_HazeBeamRepeater_Charge</defName>
		<thingClass>MoteAttached</thingClass>
		<altitudeLayer>MoteOverhead</altitudeLayer>
		<mote>
			<fadeInTime>0.15</fadeInTime>
			<fadeOutTime>0.3</fadeOutTime>
			<solidTime>999999</solidTime>
			<needsMaintenance>True</needsMaintenance>
		</mote>
		<graphicData>
			<texPath>Things/Mote/HellsphereCannon_ChargeGlow</texPath>
			<graphicClass>Graphic_MoteWithAgeSecs</graphicClass>
			<shaderType>MoteHellfireCannon_Charge</shaderType>
			<shaderParameters>
				<_RandomTex>/Things/Mote/RandomFlicker</_RandomTex>
				<_FlickerFrequency>0.25</_FlickerFrequency>
				<_FlickerAmount>0.6</_FlickerAmount>
				<_InnerCircleIntensity>0.1</_InnerCircleIntensity>
				<_InnerCircleSize>0.1</_InnerCircleSize>
				<_InnerCircleShimmerAmount>0.14</_InnerCircleShimmerAmount>
			</shaderParameters>
			<color>(85, 175, 95)</color>
		</graphicData>
	</ThingDef>

	<!-- ===== Damage Def ===== -->
	<DamageDef ParentName="Beam">
		<defName>APM_HazeAcidBeam</defName>
		<label>haze acid beam</label>
		<ignoreShields>true</ignoreShields>
	</DamageDef>

	<!-- ===== Projectile Defs ===== -->
	<ThingDef ParentName="BaseBullet">
		<defName>APM_Proj_HazeToxicRepeater</defName>
		<label>haze acid beam</label>
		<graphicData>
			<texPath>Things/Projectile/Bullet_Small</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<thingClass>ApexMechanoids.Projectile_HazeToxicRepeater</thingClass>
		<projectile>
			<damageDef>APM_HazeAcidBeam</damageDef>
			<damageAmountBase>0</damageAmountBase>
			<beamMoteDef>APM_Mote_HazeBeamRepeaterLaser</beamMoteDef>
			<beamStartOffset>0.5</beamStartOffset>
			<armorPenetrationBase>0</armorPenetrationBase>
		</projectile>
	</ThingDef>

	<ThingDef ParentName="BaseFilth">
		<defName>APM_HazeToxicPuddle</defName>
		<label>acid residue</label>
		<thingClass>ApexMechanoids.HazeToxicPuddle</thingClass>
		<tickerType>Normal</tickerType>
		<graphicData>
			<texPath>Things/Filth/Acid</texPath>
			<graphicClass>Graphic_Random</graphicClass>
			<drawSize>2.5</drawSize>
			<color>(1,1,1,0.5)</color>
		</graphicData>
		<filth>
			<ignoreFilthMultiplierStat>true</ignoreFilthMultiplierStat>
			<rainWashes>true</rainWashes>
			<cleaningWorkToReduceThickness>70</cleaningWorkToReduceThickness>
			<canFilthAttach>true</canFilthAttach>
			<maxThickness>1</maxThickness>
			<cleaningSound>Interact_CleanFilth_Fluid</cleaningSound>
		</filth>
	</ThingDef>

	<!-- ===== Weapon Def ===== -->
	<ThingDef ParentName="BaseGun">
		<defName>APM_Haze_BeamGun</defName>
		<label>haze graser cannon</label>
		<description>A tesseron's beam grazer twisted into a machine that spews toxic waste in addition to plasma, the products of this cannon are monstrously hazardous to organic life. Fear is only another foothold of the mechanoid superintelligence.</description>
		<graphicData>
			<texPath>Things/Item/Equipment/WeaponRanged/HazeBeamWitherer</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<drawSize>1.2</drawSize>
		</graphicData>
		<uiIconScale>0.5</uiIconScale>
		<techLevel>Spacer</techLevel>
		<tradeability>None</tradeability>
		<destroyOnDrop>true</destroyOnDrop>
		<relicChance>0</relicChance>
		<generateCommonality>1</generateCommonality>
		<statBases>
			<MarketValue>1000</MarketValue>
			<WorkToMake>47000</WorkToMake>
			<Mass>4.6</Mass>
			<AccuracyTouch>0.65</AccuracyTouch>
			<AccuracyShort>0.72</AccuracyShort>
			<AccuracyMedium>0.65</AccuracyMedium>
			<AccuracyLong>0.6</AccuracyLong>
			<RangedWeapon_Cooldown>3</RangedWeapon_Cooldown>
		</statBases>
		<weaponClasses>
			<li>RangedHeavy</li>
		</weaponClasses>
		<weaponTags Inherit="False">
			<li>APM_HazeGraserTag</li>
		</weaponTags>
		<verbs>
			<li>
				<verbClass>Verb_Shoot</verbClass>
				<hasStandardCommand>true</hasStandardCommand>
				<defaultProjectile>APM_Proj_HazeToxicRepeater</defaultProjectile>
				<warmupTime>2</warmupTime>
				<range>21.9</range>
				<burstShotCount>15</burstShotCount>
				<showBurstShotStats>false</showBurstShotStats>
				<ticksBetweenBurstShots>10</ticksBetweenBurstShots>
				<soundCast>Shot_ChargeBlaster</soundCast>
				<soundCastTail>GunTail_Medium</soundCastTail>
				<muzzleFlashScale>9</muzzleFlashScale>
				<aimingChargeMote>APM_Mote_HazeBeamRepeater_Charge</aimingChargeMote>
				<aimingChargeMoteOffset>1.07</aimingChargeMoteOffset>
			</li>
		</verbs>
		<tools>
			<li>
				<label>barrel</label>
				<capacities>
					<li>Blunt</li>
					<li>Poke</li>
				</capacities>
				<power>9</power>
				<cooldownTime>2</cooldownTime>
			</li>
		</tools>
	</ThingDef>

</Defs>

<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<ThingDef ParentName="BaseMeleeWeapon_Sharp_Quality">
		<defName>APM_Weapon_DominusMechlance</defName>
		<label>Dominus' mechlance</label>
		<description>This weapon is imbued with sharpness maintaining mechanites similar to those seen in imperial monotech. Such a technology being utilized by the mechhive allows the hive to apply it on larger and more complex applications, such as this deadly weapon.</description>
		<possessionCount>1</possessionCount>
		<graphicData>
			<texPath>Things/Item/Equipment/WeaponMelee/Boss/Mechlance</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<shaderType>CutoutComplex</shaderType>
			<drawSize>1.5</drawSize>
		</graphicData>
		<uiIconScale>0.5</uiIconScale>
		<equippedAngleOffset>-90</equippedAngleOffset>
		<techLevel>Spacer</techLevel>
		<weaponTags>
			<li>APM_WeaponDominusMechlance</li>
		</weaponTags>
		<thingSetMakerTags>
			<li>RewardStandardQualitySuper</li>
		</thingSetMakerTags>
		<statBases>
			<WorkToMake>18000</WorkToMake>
			<Mass>2</Mass>
		</statBases>
		<relicChance>2</relicChance>
		<costList>
			<Plasteel>50</Plasteel>
			<ComponentSpacer>2</ComponentSpacer>
		</costList>
		<tools>
			<li>
				<label>handle</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>9</power>
				<cooldownTime>2</cooldownTime>
			</li>
			<li>
				<label>point</label>
				<capacities>
					<li>Stab</li>
				</capacities>
				<power>23</power>
				<cooldownTime>2.6</cooldownTime>
			</li>
			<li>
				<label>edge</label>
				<capacities>
					<li>Cut</li>
				</capacities>
				<power>23</power>
				<cooldownTime>2.6</cooldownTime>
			</li>
		</tools>
		<recipeMaker>
			<skillRequirements>
				<Crafting>5</Crafting>
			</skillRequirements>
			<recipeUsers Inherit="false">
				<li>TableMachining</li>
			</recipeUsers>
		</recipeMaker>
		<comps>
			<li Class="ApexMechanoids.CompProperties_AbilityGranter">
				<abilities>
					<li>APM_Mech_Duel</li>
				</abilities>
			</li>
		</comps>
		<modExtensions>
			<li Class="VEF.Things.ThingDefExtension" MayRequire="OskarPotocki.VanillaFactionsExpanded.Core">
				<usableWithShields>true</usableWithShields>
				<weaponDraftedDrawOffsets>
					<north>
						<drawOffset>(-0.25, 0.00, 0.15)</drawOffset>
						<angleOffset>-20</angleOffset>
					</north>
					<east>
						<drawOffset>(0.45, 0.00, 0.15)</drawOffset>
						<angleOffset>30</angleOffset>
					</east>
					<south>
						<drawOffset>(0.25, 0.00, 0.15)</drawOffset>
						<angleOffset>20</angleOffset>
					</south>
					<west>
						<drawOffset>(-0.40  , 0.00, 0.15)</drawOffset>
						<angleOffset>250</angleOffset>
					</west>
				</weaponDraftedDrawOffsets>
			</li>
		</modExtensions>
	</ThingDef>
	

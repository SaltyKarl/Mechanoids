<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<ThingDef ParentName="BaseMeleeWeapon_Sharp_Quality">
		<defName>APM_Weapon_Exoblade</defName>
		<label>exoblade</label>
		<description>This weapon is imbued with sharpness maintaining mechanites similar to those seen in imperial monotech. Such a technology being utilized by the mechhive allows the hive to apply it on larger and more complex applications, such as this deadly weapon.</description>
		<possessionCount>1</possessionCount>
		<graphicData>
			<texPath>Things/Item/Equipment/WeaponMelee/Exoblade</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<shaderType>CutoutComplex</shaderType>
			<drawSize>1.5</drawSize>
		</graphicData>
		<uiIconScale>0.5</uiIconScale>
		<techLevel>Spacer</techLevel>
		<weaponTags>
			<li>APM_WeaponExoblade</li>
		</weaponTags>
		<thingSetMakerTags>
			<li>RewardStandardQualitySuper</li>
		</thingSetMakerTags>
		<statBases>
			<WorkToMake>40000</WorkToMake>
			<Mass>4.0</Mass>
		</statBases>
		<relicChance>2</relicChance>
		<costList>
			<Plasteel>50</Plasteel>
			<ComponentSpacer>2</ComponentSpacer>
		</costList>
		<tools>
			<li>
				<label>handle</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>9</power>
				<cooldownTime>2.0</cooldownTime>
			</li>
			<li>
				<label>point</label>
				<capacities>
					<li>Stab</li>
				</capacities>
				<power>25</power>
				<cooldownTime>2.0</cooldownTime>
			</li>
			<li>
				<label>blade</label>
				<capacities>
					<li>Cut</li>
				</capacities>
				<power>22</power>
				<cooldownTime>2.0</cooldownTime>
			</li>
		</tools>
		<recipeMaker>
			<skillRequirements>
				<Crafting>7</Crafting>
			</skillRequirements>
			<recipeUsers Inherit="false">
				<li>TableMachining</li>
			</recipeUsers>
		</recipeMaker>
		<comps>
			<li Class="ApexMechanoids.CompProperties_AbilityGranter">
				<abilities>
					<li>APM_ExobladeSeveringEdge</li>
				</abilities>
			</li>
		</comps>
		<modExtensions>
			<li Class="VEF.Things.ThingDefExtension" MayRequire="OskarPotocki.VanillaFactionsExpanded.Core">
				<usableWithShields>true</usableWithShields>
				<weaponDraftedDrawOffsets>
					<north>
						<drawOffset>(-0.05, 0.0, 0.10)</drawOffset>
						<angleOffset>190</angleOffset>
					</north>
					<east>
						<drawOffset>(0.20, 0.0, 0.10)</drawOffset>
						<angleOffset>150</angleOffset>
					</east>
					<south>
						<drawOffset>(0.05, 0.0, 0.10)</drawOffset>
						<angleOffset>160</angleOffset>
					</south>
					<west>
						<drawOffset>(-0.20, 0.0, 0.10)</drawOffset>
						<angleOffset>210</angleOffset>
					</west>
				</weaponDraftedDrawOffsets>
			</li>
		</modExtensions>
	</ThingDef>

	<AbilityDef>
		<defName>APM_ExobladeSeveringEdge</defName>
		<label>severing edge</label>
		<description>Channel the psychic energy within the exoblade to release a sweeping blade of energy in front of the wielder, cutting anything in the area.</description>
		<iconPath>UI/SeveringEdge</iconPath>
		<cooldownTicksRange>60</cooldownTicksRange>
		<aiCanUse>false</aiCanUse>
		<displayGizmoWhileUndrafted>true</displayGizmoWhileUndrafted>
		<disableGizmoWhileUndrafted>false</disableGizmoWhileUndrafted>
		<verbProperties>
			<verbClass>Verb_CastAbility</verbClass>
			<range>4.9</range>
			<warmupTime>0.3</warmupTime>
			<soundCast>APM_SeveringEdge</soundCast>
			<targetParams>
				<canTargetLocations>true</canTargetLocations>
			</targetParams>
		</verbProperties>
		<warmupMote>Mote_SeveringEdge_Intro</warmupMote>
		<moteOffsetAmountTowardsTarget>0.1</moteOffsetAmountTowardsTarget>
		<comps>
			<li Class="CompProperties_AbilityLaunchProjectile">
				<projectileDef>SeveringEdge</projectileDef>
			</li>
			<li Class="ApexMechanoids.CompProperties_RotateMoteTowardsDestination">
				<extraRotation>310</extraRotation>
			</li>
			<li Class="ApexMechanoids.CompProperties_MaintainWarmupMoteAfterCast">
				<ticksToMaintain>60</ticksToMaintain>
			</li>
		</comps>
	</AbilityDef>

</Defs>

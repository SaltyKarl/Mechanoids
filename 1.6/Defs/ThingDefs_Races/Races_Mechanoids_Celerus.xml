	<AbilityDef>
		<defName>APM_CelerusBlink</defName>
		<label>"Blink"</label>
		<description>Active onboard "blink" micro skip drive, skip to target loction.</description>
		<level>4</level>
		<iconPath>UI/Blink</iconPath>
		<cooldownTicksRange>600</cooldownTicksRange>
		<writeCombatLog>True</writeCombatLog>
		<aiCanUse>true</aiCanUse>
		<showCastingProgressBar>true</showCastingProgressBar>
		<displayGizmoWhileUndrafted>true</displayGizmoWhileUndrafted>
		<disableGizmoWhileUndrafted>false</disableGizmoWhileUndrafted>
		<casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence>
		<warmupStartSound>APM_CelerusBlink</warmupStartSound>
		<verbProperties>
			<verbClass>Verb_CastAbility</verbClass>
			<warmupTime>0.15</warmupTime>
			<soundCast>APM_CelerusBlink</soundCast>
			<range>17.9</range>
			<requireLineOfSight>True</requireLineOfSight>
			<targetParams>
				<canTargetSelf>False</canTargetSelf>
				<canTargetPawns>False</canTargetPawns>
				<canTargetBuildings>False</canTargetBuildings>
				<canTargetAnimals>False</canTargetAnimals>
				<canTargetItems>False</canTargetItems>
				<canTargetLocations>True</canTargetLocations>
				<mapObjectTargetsMustBeAutoAttackable>False</mapObjectTargetsMustBeAutoAttackable>
			</targetParams>
		</verbProperties>
		<comps>
		    <li Class="ApexMechanoids.CompProperties_BlinkWarmupVisuals">
				<pillarMoteDef>APM_Mote_Blink_WarmupPillar</pillarMoteDef>
				<ringMoteDef>APM_Mote_Blink_Ring</ringMoteDef>
				<rayMoteDef>APM_Mote_Blink_WarmupRay</rayMoteDef>
				<sparkleMoteDef>APM_Mote_Blink_Sparkle</sparkleMoteDef>
				<spawnIntervalTicks>20</spawnIntervalTicks>
				<sparklesPerPulse>2</sparklesPerPulse>
			</li>
			<li Class="ApexMechanoids.CompProperties_BlinkTeleport">
				<destination>Selected</destination>
				<requiresLineOfSight>True</requiresLineOfSight>
				<range>17.9</range>
				<clamorType>Ability</clamorType>
				<clamorRadius>10</clamorRadius>
				<destClamorType>Ability</destClamorType>
				<destClamorRadius>10</destClamorRadius>
				<ringMoteDef>APM_Mote_Blink_Ring</ringMoteDef>
				<starAMoteDef>APM_Mote_Blink_StarA</starAMoteDef>
				<starBMoteDef>APM_Mote_Blink_StarB</starBMoteDef>
				<sparkleMoteDef>APM_Mote_Blink_Sparkle</sparkleMoteDef>
				<arrivalPillarMoteDef>APM_Mote_Blink_WarmupPillar</arrivalPillarMoteDef>
				<arrivalRayMoteDef>APM_Mote_Blink_WarmupRay</arrivalRayMoteDef>
				<darkFragmentMoteDefs>
					<li>APM_Mote_Blink_DarkFragment_A</li>
					<li>APM_Mote_Blink_DarkFragment_B</li>
					<li>APM_Mote_Blink_DarkFragment_C</li>
					<li>APM_Mote_Blink_DarkFragment_D</li>
				</darkFragmentMoteDefs>
				<darkFragmentCount>1~1</darkFragmentCount>
			</li>
		</comps>
	</AbilityDef>
